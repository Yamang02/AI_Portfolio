environment          = "staging"
aws_region           = "ap-northeast-2"
gcp_project_id       = "your-gcp-project-id"
gcp_region           = "asia-northeast3"
# staging.yamang02.com — 실제로는 와일드카드 ACM (us-east-1) 사용
acm_certificate_arn  = "arn:aws:acm:us-east-1:601326494743:certificate/1ef36112-08b6-4481-8bed-12996dca0c27"
cloudfront_origin_id = "ai-portfolio-fe-staging.s3.ap-northeast-2.amazonaws.com-mfkn4ut0748"

# Cloud Run — gcloud run services describe <name> --region <region> --format="value(spec.template.spec.serviceAccountName)"
# 전용 SA 권장. postgres 모듈이 동일 이메일에 roles/cloudsql.client 부여(Cloud Run Unix 소켓 연결).
# (gcp-backend는 template/traffic을 ignore하므로 이미지 값은 import·참고용·plan 경고 완화용)
cloud_run_service_account_email = "sa-your-app-staging@your-gcp-project-id.iam.gserviceaccount.com"
cloud_run_container_image         = "gcr.io/your-gcp-project-id/ai-portfolio-staging:IMAGE_TAG_OR_DIGEST"

# 선택: 본인 Google 계정에 Cloud SQL 관리자(콘솔·gcloud). 형식은 IAM member 전체.
# gcp_cloudsql_admin_member = "user:you@gmail.com"

# 선택: GitHub Actions 배포 SA가 프로젝트 기본값과 다를 때만
# github_actions_deployer_service_account_email = "github-actions@your-project-id.iam.gserviceaccount.com"
